{
  "name": "pkic-org-events-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c 'hugo serve -w -e development --port 1313 & HUGO_PID=$!; trap \"kill $HUGO_PID\" EXIT INT TERM; npx wrangler pages dev --ip 0.0.0.0 --proxy 1313'",
    "dev:hugo": "hugo serve -w -e development",
    "dev:wrangler": "npx wrangler pages dev --ip 0.0.0.0 --proxy 1313",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "tsc --noEmit -p tsconfig.json",
    "typecheck:frontend": "tsc --noEmit -p tsconfig.frontend.json",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "vitest run tests --exclude='tests/frontend/**' --exclude='**/tests/frontend/**'",
    "test:frontend": "vitest run tests/frontend",
    "test:workflows": "vitest run tests/full-workflow.test.ts",
    "test:watch": "vitest",
    "check:max-lines": "node scripts/check-max-lines.mjs",
    "check": "npm run typecheck && npm run test && npm run check:max-lines",
    "wrangler:types": "npx wrangler types",
    "seed:local": "node scripts/seed.mjs --local",
    "seed:preview": "node scripts/seed.mjs --preview",
    "seed:production": "node scripts/seed.mjs --production"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "handlebars": "^4.7.8",
    "ics": "^3.8.1",
    "marked": "^17.0.3",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.1",
    "better-sqlite3": "^12.4.1",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
