{
  "name": "pkic-org-events-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx wrangler dev --env local --ip 0.0.0.0 --port 8788",
    "dev:hugo": "hugo serve",
    "deploy": "npx wrangler deploy --env production",
    "deploy:preview": "npx wrangler deploy --env preview",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "tsc --noEmit -p tsconfig.json",
    "typecheck:frontend": "tsc --noEmit -p tsconfig.frontend.json",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "vitest run --config vitest.config.ts",
    "test:frontend": "vitest run --config vitest.config.frontend.ts",
    "test:workflows": "vitest run --config vitest.config.ts tests/full-workflow.test.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "check:max-lines": "node scripts/check-max-lines.mjs",
    "check": "npm run typecheck && npm run test && npm run check:max-lines",
    "wrangler:types": "npx wrangler types --env local",
    "seed:local": "node scripts/seed.mjs --local",
    "seed:preview": "node scripts/seed.mjs --preview",
    "seed:production": "node scripts/seed.mjs --production"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "chanfana": "^3.3.0",
    "handlebars": "^4.7.9",
    "hono": "^4.12.10",
    "ical.js": "^2.2.1",
    "marked": "^17.0.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.1",
    "jsdom": "^27.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp"
    ]
  }
}
